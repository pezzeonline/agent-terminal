# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# Common global gitignores (Python virtualenv `ENV/`) case-insensitively
# match src/modules/env/ on macOS. Un-ignore the source folder here so
# our env config modules always get tracked.
!src/modules/env/
!src/modules/env/**

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# fallow.tools local cache
.fallow/

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android
